#!/usr/bin/env bash
# run_once_04-install-packages: initial package installation for this machine.
# run_onchange_install-packages.sh handles subsequent re-runs when the manifest changes.

set -euo pipefail

REPO_DIR="{{ .chezmoi.sourceDir }}/.."
SCRIPT="$REPO_DIR/scripts/install_packages.py"

if ! command -v uv &>/dev/null; then
    echo "ERROR: uv is not installed. It should have been installed by run_once_02."
    echo "  Re-run: chezmoi apply"
    exit 1
fi

echo "==> Installing packages from packages.yaml..."
uv run --script "$SCRIPT" \
    --packages "$REPO_DIR/packages/packages.yaml" \
    --profile  "{{ .profile }}" \
    --machine  "{{ .machine }}" \
    --os       "{{ .chezmoi.os }}" \
    --os-id    "{{ if .chezmoi.osRelease }}{{ .chezmoi.osRelease.id }}{{ end }}" \
    {{ if .prefer_system_packages }}--prefer-system-packages{{ end }}
