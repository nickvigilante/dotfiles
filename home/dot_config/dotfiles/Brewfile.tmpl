# Unified Brewfile — rendered to ~/.config/dotfiles/Brewfile by chezmoi.
# Source: home/dot_config/dotfiles/Brewfile.tmpl
# Edit this template; run `chezmoi apply` to regenerate.

# ── Taps ─────────────────────────────────────────────────────────────────────
{{ if eq .profile "work" -}}
tap "coder/coder"
{{- end }}

# ── Cross-platform CLI (every full-toolkit machine) ──────────────────────────
brew "git"           # Distributed revision control
brew "curl"          # HTTP client
brew "wget"          # File retriever
brew "jq"            # JSON processor
brew "ripgrep"       # Fast grep (rg)
brew "fd"            # Fast find
brew "fzf"           # Fuzzy finder
brew "eza"           # Better ls
brew "bat"           # Better cat (syntax highlighting)
brew "zoxide"        # Better cd
brew "tldr"          # Simplified man pages
brew "htop"          # Process viewer
brew "tree"          # Directory tree
brew "tmux"          # Terminal multiplexer
brew "neovim"        # Editor
brew "gh"            # GitHub CLI
brew "git-delta"     # Better git diff
brew "lazygit"       # TUI git client
brew "ncdu"          # NCurses Disk Usage
brew "uv"            # Python package manager (Astral)
brew "ruff"          # Python linter (Astral)
brew "gnupg"         # OpenPGP
brew "age"           # Modern encryption
brew "chezmoi"       # Dotfiles manager
brew "gum"           # Charm shell UI
brew "just"          # Command runner / project Makefile alternative
brew "mprocs"        # Run multiple commands in parallel
brew "go"            # Go language
brew "rust"          # Rust language
brew "node"          # Node.js
brew "prettier"      # Code formatter

# ── macOS-only formulae ──────────────────────────────────────────────────────
{{ if eq .chezmoi.os "darwin" -}}
brew "mas"           # Mac App Store CLI
brew "duti"          # Default-app picker
brew "grep"          # GNU grep (better than BSD)
brew "gnupg"         # (already above; macOS sometimes needs explicit)
{{- end }}

# ── Secrets CLIs ─────────────────────────────────────────────────────────────
{{ if or (eq .secrets "bitwarden") (eq .secrets "both") -}}
brew "bitwarden-cli"
{{- end }}
{{ if or (eq .secrets "1password") (eq .secrets "both") -}}
{{- if eq .chezmoi.os "darwin" }}
cask "1password-cli"
{{- end }}
{{- end }}

# ── Work-only formulae ───────────────────────────────────────────────────────
{{ if eq .profile "work" -}}
brew "vale"             # Prose linter
brew "cmake"            # Build tool (TileDB C++)
brew "coder/coder/coder" # Coder.com remote dev
brew "openapi-generator"
brew "halibut"          # Document preparation
brew "pandoc"           # Markup converter
brew "weasyprint"       # HTML → PDF
brew "zola"             # Static site generator
brew "gopls"            # Go language server
brew "colima"           # Container runtime (macOS/Linux)
brew "docker"           # Docker CLI
brew "snap"             # snap CLI on macOS (.snap files)
brew "tailscale"        # Mesh VPN (CLI)
{{- end }}

# ── Personal-only formulae ───────────────────────────────────────────────────
{{ if eq .profile "personal" -}}
brew "fish"          # Friendly shell (alternative)
brew "ollama"        # Local LLM runtime
{{- end }}

