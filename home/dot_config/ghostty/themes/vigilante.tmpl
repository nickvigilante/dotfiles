# Vigilante theme — generated from home/.chezmoidata/palette.toml.
# Format: Ghostty theme syntax (one key=value per line).

palette = 0={{ .palette.ansi.black }}
palette = 1={{ .palette.ansi.red }}
palette = 2={{ .palette.ansi.green }}
palette = 3={{ .palette.ansi.yellow }}
palette = 4={{ .palette.ansi.blue }}
palette = 5={{ .palette.ansi.magenta }}
palette = 6={{ .palette.ansi.cyan }}
palette = 7={{ .palette.ansi.white }}
palette = 8={{ .palette.ansi.bright_black }}
palette = 9={{ .palette.ansi.bright_red }}
palette = 10={{ .palette.ansi.bright_green }}
palette = 11={{ .palette.ansi.bright_yellow }}
palette = 12={{ .palette.ansi.bright_blue }}
palette = 13={{ .palette.ansi.bright_magenta }}
palette = 14={{ .palette.ansi.bright_cyan }}
palette = 15={{ .palette.ansi.bright_white }}

background = {{ .palette.bg.default }}
foreground = {{ .palette.fg.default }}
cursor-color = {{ .palette.accent.green }}
selection-background = {{ .palette.bg.highlight }}
selection-foreground = {{ .palette.fg.bright }}
