# Environment exports — profile and platform aware.
# Sourced by .zshrc for interactive shells.

# ── Editor ────────────────────────────────────────────────────────────────────
export EDITOR="vim"
export VISUAL="$EDITOR"

# ── Locale ────────────────────────────────────────────────────────────────────
export LANG="en_US.UTF-8"
export LC_ALL="en_US.UTF-8"

# ── History ───────────────────────────────────────────────────────────────────
# Oh My ZSH sets sensible defaults, but raise the limits.
export HISTSIZE=100000
export SAVEHIST=100000
export HISTFILE="$HOME/.zsh_history"

# ── Pager / man ───────────────────────────────────────────────────────────────
export LESS="-R --use-color"
export MANPAGER="less -R --use-color -Dd+r -Du+b"

# ── bat (better cat) ──────────────────────────────────────────────────────────
export BAT_THEME="Monokai Extended"

# ── ripgrep ───────────────────────────────────────────────────────────────────
export RIPGREP_CONFIG_PATH="${XDG_CONFIG_HOME:-$HOME/.config}/ripgrep/config"

# ── fzf ───────────────────────────────────────────────────────────────────────
export FZF_DEFAULT_COMMAND="fd --type f --hidden --follow --exclude .git"
export FZF_DEFAULT_OPTS="--height 40% --layout=reverse --border"

# ── Profile-specific ──────────────────────────────────────────────────────────
{{ if eq .profile "work" -}}
# Work profile — add work-specific exports here.
# export AWS_PROFILE="work"
{{ else -}}
# Personal profile — add personal exports here.
{{ if ne .machine "server" -}}

# ── Homelab k3s ───────────────────────────────────────────────────────────────
# Drive the home-lab cluster from this device over the tailnet. The kubeconfig
# is deployed by chezmoi to ~/.kube/homelab.yaml (Bitwarden-sourced, personal
# non-server devices only — see .chezmoiignore). Prepend it so kubectl/helm
# work out of the box, while preserving any other KUBECONFIG entries.
export KUBECONFIG="$HOME/.kube/homelab.yaml${KUBECONFIG:+:$KUBECONFIG}"
{{ end -}}
{{- end }}
