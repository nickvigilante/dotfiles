{
  // ── Editor ─────────────────────────────────────────────────────────────────
  "editor.fontFamily": "'JetBrainsMono Nerd Font', 'Fira Code', monospace",
  "editor.fontSize": 13,
  "editor.lineHeight": 1.5,
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.rulers": [88],
  "editor.formatOnSave": true,
  "editor.formatOnPaste": false,
  "editor.minimap.enabled": false,
  "editor.renderWhitespace": "boundary",
  "editor.wordWrap": "off",
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",
  "editor.inlayHints.enabled": "on",
  "editor.suggest.preview": true,
  "editor.acceptSuggestionOnEnter": "smart",
  "editor.stickyScroll.enabled": true,

  // ── Terminal ────────────────────────────────────────────────────────────────
  "terminal.integrated.fontFamily": "'JetBrainsMono Nerd Font'",
  "terminal.integrated.fontSize": 13,
  {{- if eq .chezmoi.os "darwin" }}
  "terminal.integrated.defaultProfile.osx": "zsh",
  {{- else if eq .chezmoi.os "linux" }}
  "terminal.integrated.defaultProfile.linux": "zsh",
  {{- end }}

  // ── Files ───────────────────────────────────────────────────────────────────
  "files.trimTrailingWhitespace": true,
  "files.trimFinalNewlines": false,
  "files.insertFinalNewline": true,
  "files.autoSave": "onFocusChange",
  "files.exclude": {
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/.mypy_cache": true,
    "**/target": true,
    "**/.DS_Store": true
  },

  // ── Python ─────────────────────────────────────────────────────────────────
  // Uses Black for formatting (88-char line length matches the default).
  // isort profile "black" keeps import sorting compatible with Black.
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.formatOnSave": true,
    "editor.rulers": [88],
    "editor.tabSize": 4
  },
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.autoImportCompletions": true,
  "python.defaultInterpreterPath": "~/venv/bin/python",
  "black-formatter.args": ["--line-length", "88"],
  "isort.args": ["--profile", "black"],

  // ── Rust ───────────────────────────────────────────────────────────────────
  // Rust convention is 100 chars (rustfmt default).
  // Clippy is stricter than the default check — catches more issues.
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer",
    "editor.formatOnSave": true,
    "editor.rulers": [100]
  },
  "rust-analyzer.check.command": "clippy",
  "rust-analyzer.checkOnSave": true,
  "rust-analyzer.inlayHints.typeHints.enable": true,
  "rust-analyzer.inlayHints.parameterHints.enable": true,
  "rust-analyzer.inlayHints.closureReturnTypeHints.enable": "with_block",

  // ── Git ─────────────────────────────────────────────────────────────────────
  "git.enableSmartCommit": true,
  "git.confirmSync": false,
  "git.decorations.enabled": true,
  "diffEditor.ignoreTrimWhitespace": false,

  // ── Workbench ────────────────────────────────────────────────────────────────
  "workbench.colorTheme": "Default Dark Modern",
  "workbench.startupEditor": "none",
  "workbench.editor.highlightModifiedTabs": true,

  // ── Extensions ───────────────────────────────────────────────────────────────
  "extensions.autoUpdate": "onlyEnabledExtensions",

  // ── Profile: {{ .profile }} ──────────────────────────────────────────────────
  {{- if eq .profile "work" }}
  "git.defaultCloneDirectory": "~/work",
  "telemetry.telemetryLevel": "off"
  {{- else }}
  "telemetry.telemetryLevel": "off"
  {{- end }}
}
