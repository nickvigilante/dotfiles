#!/usr/bin/env bash
# run_once_06-touchid-sudo: enable Touch ID for sudo on macOS.
#
# Uses /etc/pam.d/sudo_local (NOT /etc/pam.d/sudo) because sudo_local is
# preserved across macOS system updates. /etc/pam.d/sudo gets overwritten.
{{ if ne .chezmoi.os "darwin" }}exit 0{{ end }}

set -euo pipefail

SUDO_LOCAL="/etc/pam.d/sudo_local"

# Guard: make sure this macOS version still uses the sudo_local include pattern.
# If Apple changes PAM structure in a future macOS version, bail out safely.
if ! grep -q "sudo_local" /etc/pam.d/sudo 2>/dev/null; then
    echo "WARNING: /etc/pam.d/sudo does not include sudo_local."
    echo "Apple may have changed the PAM structure in this macOS version."
    echo "Touch ID sudo setup skipped — configure manually if needed."
    exit 0
fi

# Idempotency: already configured.
if grep -q "pam_tid" "$SUDO_LOCAL" 2>/dev/null; then
    echo "Touch ID for sudo already configured."
    exit 0
fi

echo "Enabling Touch ID for sudo (requires sudo access)..."

sudo tee "$SUDO_LOCAL" > /dev/null <<'EOF'
# sudo_local: local config file which survives system updates.
# Allows Touch ID to authenticate sudo.
auth       sufficient     pam_tid.so
EOF

echo "Touch ID for sudo enabled."
echo "Open a new terminal and run 'sudo ls' to test it."
