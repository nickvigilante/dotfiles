# chezmoi ignore rules (this file is itself templated).
#
# The home-lab admin kubeconfig (~/.kube/homelab.yaml) is a cluster-admin
# credential. Deploy it ONLY on personal, non-server devices — never work
# machines (profile != "personal"), and not on the cluster nodes themselves
# (machine == "server", which already have /etc/rancher/k3s/k3s.yaml). The
# matching KUBECONFIG export in dot_config/shell/exports.zsh.tmpl uses the
# same gate. See homelab #132.
{{ if or (ne .profile "personal") (eq .machine "server") -}}
.kube/homelab.yaml
{{ end -}}

# ─── Home-directory audit (dotfiles #28) ──────────────────────────────────
# Record of unmanaged files deliberately kept OUT of management, so the
# decision is explicit. Most live only on the machine that needs them.
#
# Secrets / credentials — NEVER track in plaintext. If one ever needs to
# reproduce across machines, template it via Bitwarden (see .kube above).
# (.config/gh/hosts.yml is the secret sibling of the tracked gh/config.yml;
# it holds the GitHub host/user identity, and off macOS the OAuth token.)
.config/gh/hosts.yml
.config/rclone/rclone.conf
.simplefin_access_url
.simplefin_token
.pi/agent/auth.json
.terraform.d/credentials.tfrc.json
.claude.json
#
# Intentional non-secret excludes (stock defaults, machine state, or obsolete):
#   .bashrc / .profile          stock Ubuntu + machine-local conda init
#   .hyper.js / .config/tabby    obsolete — migrated to ghostty (managed)
#   .config/Vial/Vial.conf       window-geometry state only; pending homelab #179
#   .config/monitors.xml         machine-specific display layout
#   .config/QtProject.conf       Qt file-dialog state, not config
#   .config/user-dirs.dirs       stock XDG defaults
#   .config/xclicker.conf        low-value app state
#   .yarnrc                      autogenerated update-check timestamp
#   .pi/agent/settings.json      .pi agent tool — excluded entirely
#   browsers / Signal / Proton / caches / toolchain dirs   not portable config
# ──────────────────────────────────────────────────────────────────────────
