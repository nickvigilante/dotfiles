{{- /* ~/.env — runtime secrets, chmod 600 (enforced by chezmoi's private_ prefix).
     Sourced by ~/.zshenv on every shell start.
     This file is generated by chezmoi from home/private_dot_env.tmpl.
     Edit the template (chezmoi edit ~/.env), not this file directly.

     To add a secret from Bitwarden, use one of these template expressions:
       Password:     {{ (bitwarden "item" "Item Name").login.password }}
       Custom field: {{ (bitwardenFields "item" "Item Name").field_name.value }}
       Secure note:  {{ (bitwarden "item" "Note Name").notes }}

     To add a secret from 1Password (work profile only):
       Any field:    {{ onepasswordRead "op://Vault/Item/field" }}

     Before running `chezmoi apply`, unlock your vault(s):
       Personal (all machines): export BW_SESSION=$(bw unlock --raw)
       Work (work machine):     op signin  (uses system keychain after first time)

     Use `bw-apply` (defined in ~/.config/shell/functions.zsh) to unlock + apply in one step.
*/ -}}

{{- /* ── Personal secrets (Bitwarden — all machines except Pi) ────────────────── */ -}}
{{- if ne .machine "pi" }}

# Personal secrets — populate by editing: chezmoi edit ~/.env
# Example:
# export GITHUB_TOKEN="{{ "{{" }} (bitwarden "item" "GitHub PAT").login.password {{ "}}" }}"

{{- end }}

{{- /* ── Work secrets (1Password — work machine only) ────────────────────────── */ -}}
{{- if eq .profile "work" }}

# Work secrets — populate by editing: chezmoi edit ~/.env
# Example:
# export AWS_ACCESS_KEY_ID="{{ "{{" }} onepasswordRead "op://Work/AWS/access_key_id" {{ "}}" }}"

{{- end }}
