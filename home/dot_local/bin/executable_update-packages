#!/usr/bin/env bash
# update-packages: check for and install updates across all package managers.
# Throttled to once per 24 hours. Run with --force to bypass the throttle.
# Launched in the background by ~/.zshrc on every new shell.

set -euo pipefail

STAMP_FILE="${XDG_CACHE_HOME:-$HOME/.cache}/dotfiles/last_update"
THROTTLE_SECONDS=86400  # 24 hours

# ── Throttle check ─────────────────────────────────────────────────────────────
mkdir -p "$(dirname "$STAMP_FILE")"

if [[ -f "$STAMP_FILE" ]] && [[ "${1:-}" != "--force" ]]; then
    last=$(cat "$STAMP_FILE")
    now=$(date +%s)
    elapsed=$(( now - last ))
    if (( elapsed < THROTTLE_SECONDS )); then
        exit 0  # Not time yet — silent exit
    fi
fi

echo "$(date +%s)" > "$STAMP_FILE"

echo ""
echo "┌─────────────────────────────────────────────┐"
echo "│  Package updates available — running now... │"
echo "└─────────────────────────────────────────────┘"
echo ""

# ── Detect platform ────────────────────────────────────────────────────────────
OS="unknown"
DISTRO=""
case "$(uname -s)" in
    Darwin)   OS="macos" ;;
    Linux)
        OS="linux"
        if [[ -f /etc/os-release ]]; then
            DISTRO=$(. /etc/os-release && echo "$ID")
        fi
        ;;
    CYGWIN*|MINGW*|MSYS*) OS="windows" ;;
esac

# ── Updater functions ──────────────────────────────────────────────────────────
run_update() {
    local label="$1"; shift
    echo "→ $label..."
    "$@" && echo "  ✓ $label done." || echo "  ✗ $label failed (non-fatal)."
}

update_brew() {
    command -v brew &>/dev/null || return 0
    run_update "Homebrew" brew update
    run_update "Homebrew upgrade" brew upgrade
    run_update "Homebrew cleanup" brew cleanup
}

update_apt() {
    command -v apt &>/dev/null || return 0
    run_update "apt" sudo apt update
    run_update "apt upgrade" sudo apt upgrade -y
    run_update "apt autoremove" sudo apt autoremove -y
}

update_dnf() {
    command -v dnf &>/dev/null || return 0
    run_update "dnf upgrade" sudo dnf upgrade -y
}

update_snap() {
    command -v snap &>/dev/null || return 0
    run_update "snap" sudo snap refresh
}

update_choco() {
    command -v choco &>/dev/null || return 0
    run_update "Chocolatey" choco upgrade all -y
}

update_chezmoi() {
    command -v chezmoi &>/dev/null || return 0
    run_update "chezmoi" chezmoi upgrade
}

# ── Run updates for this platform ─────────────────────────────────────────────
case "$OS" in
    macos)
        update_brew
        update_chezmoi
        ;;
    linux)
        case "$DISTRO" in
            ubuntu|debian)            update_apt  ;;
            raspbian)                 update_apt  ;;
            fedora|rhel|centos)       update_dnf  ;;
        esac
        update_brew
        update_snap
        update_chezmoi
        ;;
    windows)
        update_choco
        update_chezmoi
        ;;
esac

echo ""
echo "✓ All updates complete: $(date)"
echo ""
