# ~/.zshenv — sourced for ALL zsh shells (interactive, non-interactive, scripts).
# Keep this minimal: PATH and env vars that non-interactive shells and scripts need.
# Everything else goes in .zshrc.

# ── XDG Base Directory ─────────────────────────────────────────────────────────
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"

# ── PATH ───────────────────────────────────────────────────────────────────────
# Personal scripts and tools (chezmoi, uv, etc. install here)
export PATH="$HOME/.local/bin:$PATH"

# Cargo (Rust toolchain, also used by some tools like uv)
export PATH="$HOME/.cargo/bin:$PATH"

# uv home venv — the default Python for this machine.
# When inside a project directory with its own .venv, uv prefers that instead.
export PATH="$HOME/venv/bin:$PATH"
export VIRTUAL_ENV="$HOME/venv"
export UV_PYTHON_PREFERENCE="only-managed"

{{- if or (eq .secrets "1password") (eq .secrets "both") }}

# 1Password service-account token (ephemeral / headless machines)
if [[ -z "${OP_SERVICE_ACCOUNT_TOKEN:-}" ]] && [[ -f "$HOME/.config/op/token" ]]; then
    export OP_SERVICE_ACCOUNT_TOKEN="$(cat "$HOME/.config/op/token")"
fi
{{- end }}

{{- if or (eq .secrets "bitwarden") (eq .secrets "both") }}

# Bitwarden SSH agent — exposed by the Bitwarden desktop app at this socket
# when "SSH agent" is enabled in its settings. Gate on socket presence so
# ssh still works (via the system agent or no agent) when the desktop app
# isn't running or the toggle is off.
if [[ -S "$HOME/.bitwarden-ssh-agent.sock" ]]; then
    export SSH_AUTH_SOCK="$HOME/.bitwarden-ssh-agent.sock"
fi
{{- end }}

# ── Secrets ────────────────────────────────────────────────────────────────────
# ~/.env is generated by chezmoi from a template (never committed to the repo).
# It holds API keys and other runtime secrets.
[[ -f "$HOME/.env" ]] && source "$HOME/.env"
