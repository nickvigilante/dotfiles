#!/usr/bin/env bash
# run_onchange_install-packages: re-sync packages whenever packages.yaml changes.
# chezmoi re-runs this script when its content changes. The hash below embeds
# the package manifest so any edit to that file triggers a re-run.
#
# packages.yaml: {{ include (joinPath .chezmoi.sourceDir "../packages/packages.yaml") | sha256sum }}

set -euo pipefail

REPO_DIR="{{ .chezmoi.sourceDir }}/.."
SCRIPT="$REPO_DIR/scripts/install_packages.py"

if ! command -v uv &>/dev/null; then
    echo "ERROR: uv is not installed. Run bootstrap/install.sh or install uv manually."
    echo "  See: https://docs.astral.sh/uv/getting-started/installation/"
    exit 1
fi

echo "==> Syncing packages from packages.yaml..."
uv run --script "$SCRIPT" \
    --packages "$REPO_DIR/packages/packages.yaml" \
    --profile  "{{ .profile }}" \
    --machine  "{{ .machine }}" \
    --os       "{{ .chezmoi.os }}" \
    --os-id    "{{ if .chezmoi.osRelease }}{{ .chezmoi.osRelease.id }}{{ end }}" \
    {{ if .prefer_system_packages }}--prefer-system-packages{{ end }}
