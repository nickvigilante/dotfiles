#!/usr/bin/env bash
# run_onchange_install-packages: re-sync packages whenever package lists change.
# chezmoi re-runs this script when its content changes. The comment lines below
# embed the package file contents, so any edit to those files triggers a re-run.
#
# Brewfile:       {{ include (joinPath .chezmoi.sourceDir "../os/macos/Brewfile") | sha256sum }}
# Brewfile.linux: {{ include (joinPath .chezmoi.sourceDir "../os/linux/Brewfile.linux") | sha256sum }}
# packages.apt:   {{ include (joinPath .chezmoi.sourceDir "../os/linux/packages.apt") | sha256sum }}
# packages.dnf:   {{ include (joinPath .chezmoi.sourceDir "../os/linux/packages.dnf") | sha256sum }}
# packages.pi:    {{ include (joinPath .chezmoi.sourceDir "../os/raspberry-pi/packages.apt") | sha256sum }}
# packages.choco: {{ include (joinPath .chezmoi.sourceDir "../os/windows/packages.choco") | sha256sum }}

set -euo pipefail

REPO_DIR="{{ .chezmoi.sourceDir }}/.."

{{ if eq .chezmoi.os "darwin" -}}
if [[ -f "$REPO_DIR/os/macos/Brewfile" ]]; then
    echo "==> Syncing macOS Homebrew packages..."
    brew bundle install --file="$REPO_DIR/os/macos/Brewfile" --no-lock
fi

{{ else if eq .chezmoi.os "linux" -}}

{{ if eq .machine "pi" -}}
if [[ -f "$REPO_DIR/os/raspberry-pi/packages.apt" ]]; then
    echo "==> Syncing Raspberry Pi apt packages..."
    sudo apt update
    grep -Ev '^#|^$' "$REPO_DIR/os/raspberry-pi/packages.apt" | xargs sudo apt install -y
fi
{{ else if or (eq .chezmoi.osRelease.id "ubuntu") (eq .chezmoi.osRelease.id "debian") -}}
if [[ -f "$REPO_DIR/os/linux/packages.apt" ]]; then
    echo "==> Syncing Ubuntu/Debian apt packages..."
    sudo apt update
    grep -Ev '^#|^$' "$REPO_DIR/os/linux/packages.apt" | xargs sudo apt install -y
fi
{{ else if eq .chezmoi.osRelease.id "fedora" -}}
if [[ -f "$REPO_DIR/os/linux/packages.dnf" ]]; then
    echo "==> Syncing Fedora dnf packages..."
    grep -Ev '^#|^$' "$REPO_DIR/os/linux/packages.dnf" | xargs sudo dnf install -y
fi
{{- end }}

{{ if ne .machine "pi" -}}
if command -v brew &>/dev/null && [[ -f "$REPO_DIR/os/linux/Brewfile.linux" ]]; then
    echo "==> Syncing Linux Homebrew packages..."
    brew bundle install --file="$REPO_DIR/os/linux/Brewfile.linux" --no-lock
fi
{{- end }}

{{ else if eq .chezmoi.os "windows" -}}
if [[ -f "$REPO_DIR/os/windows/packages.choco" ]]; then
    echo "==> Syncing Windows Chocolatey packages..."
    grep -Ev '^#|^$' "$REPO_DIR/os/windows/packages.choco" | xargs choco install -y
fi
{{- end }}

echo "==> Package sync complete."
