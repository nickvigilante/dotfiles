{
  "permissions": {
    "defaultMode": "auto",
    "allow": [
{{- range $base, $spec := .permissions.commands }}
{{-   $heads := list $base }}
{{-   if has $base $.permissions.rtk_wraps }}{{ $heads = append $heads (printf "rtk %s" $base) }}{{ end }}
{{-   if hasKey $spec "extra_heads" }}{{ range $eh := $spec.extra_heads }}{{ $heads = append $heads $eh }}{{ end }}{{ end }}
{{-   range $head := $heads }}
{{-     range $arg := $spec.args }}
      "Bash({{ $head }} {{ $arg }})",
{{-     end }}
{{-   end }}
{{- end }}
{{- range $tool := .permissions.rtk_only_tools }}
      "Bash(rtk {{ $tool }} *)",
{{- end }}
      "Bash(chezmoi diff *)",
      "Bash(chezmoi status *)",
      "Bash(chezmoi data)",
      "Bash(chezmoi doctor)",
      "Bash(chezmoi verify *)",
      "Bash(chezmoi cat *)",
      "Bash(chezmoi managed *)",
      "Bash(chezmoi unmanaged *)",
      "Bash(chezmoi ignored *)",
      "Bash(chezmoi target-path *)",
      "Bash(chezmoi source-path *)",
      "Bash(brew info *)",
      "Bash(brew search *)",
      "Bash(brew outdated)",
      "Bash(brew deps *)",
      "Bash(brew uses *)",
      "Bash(brew leaves)",
      "Bash(brew desc *)",
      "Bash(brew doctor)",
      "Bash(brew tap-info *)",
      "Bash(brew bundle check *)",
      "Bash(brew bundle list *)",
      "Bash(brew list)",
      "Bash(brew list *)",
      "Bash(brew tap)",
      "Bash(rustup show)",
      "Bash(rustup target list)",
      "Bash(rustup toolchain list)",
      "Bash(rustup component list *)",
      "Bash(rustup check)",
      "Bash(sw_vers)",
      "Bash(defaults read *)",
      "Bash(system_profiler *)",
      "Bash(mdls *)",
      "Bash(plutil -p *)",
      "Bash(diskutil info *)",
      "Bash(diskutil list)",
      "Bash(pkgutil --pkgs *)",
      "Bash(pkgutil --pkg-info *)",
      "Bash(xcode-select -p)",
      "Bash(launchctl list *)",
      "Bash(softwareupdate -l)",
      "Bash(duti -x *)",
      "Bash(duti -l *)",
      "Bash(shellcheck *)",
      "Bash(gitleaks version)",
      "Bash(gitleaks git *)",
      "Bash(ffmpeg -version)",
      "Bash(ffprobe *)",
      "Bash(cf-terraforming version)",
      "Bash(helm version*)",
      "Bash(helm env)",
      "Bash(helm list*)",
      "Bash(helm ls*)",
      "Bash(helm status *)",
      "Bash(helm history *)",
      "Bash(helm get hooks *)",
      "Bash(helm get notes *)",
      "Bash(helm get metadata *)",
      "Bash(helm repo list*)",
      "Bash(helm search *)",
      "Bash(helm dependency list *)",
      "Bash(helm lint *)",
      "Bash(helm template *)",
      "Bash(helm plugin list)",
      "Bash(rtk gain *)",
      "Bash(rtk discover)",
      "Bash(rtk cc-economics *)",
      "Bash(rtk session *)",
      "Bash(rtk config show)",
      "Bash(rtk --version)",
      "Bash(rtk --help)",
      "Bash(jq *)",
      "Bash(stat *)",
      "Bash(file *)",
      "Bash(which *)",
      "Bash(tail *)",
      "Bash(date *)",
      "Bash(echo \"exit $?\")",
      "Bash(echo exit $?)",
      "Bash(echo $?)",
      "Bash(pwd)",
      "Bash(true)",
      "Bash(:)"
    ],
    "deny": [
      "Bash(git branch -d *)",
      "Bash(git branch -D *)",
      "Bash(git branch --delete *)",
      "Bash(rtk git branch -d *)",
      "Bash(rtk git branch -D *)",
      "Bash(rtk git branch --delete *)"
    ]
  },
  "model": "claude-opus-4-8",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          },
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/permission-prefilter.py\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/claude-config-drift.sh\""
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": false,
    "superpowers@claude-plugins-official": true,
    "cloudflare@claude-plugins-official": false,
    "warp@claude-code-warp": true,
    "frontend-design@claude-plugins-official": false,
    "github@claude-plugins-official": false,
    "skill-creator@claude-plugins-official": false,
    "security-guidance@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": false,
    "code-review@claude-plugins-official": false,
    "context7@claude-plugins-official": false,
    "feature-dev@claude-plugins-official": false,
    "claude-code-setup@claude-plugins-official": false,
    "pr-review-toolkit@claude-plugins-official": false,
    "plugin-dev@claude-plugins-official": false,
    "playground@claude-plugins-official": false,
    "explanatory-output-style@claude-plugins-official": true,
    "mcp-server-dev@claude-plugins-official": false
  },
  "skillOverrides": {
    "notion-mcp-waf": "off"
  },
  "extraKnownMarketplaces": {
    "claude-code-warp": {
      "source": {
        "source": "github",
        "repo": "warpdotdev/claude-code-warp"
      }
    }
  },
  "tui": "fullscreen",
  "theme": "dark",
  "remoteControlAtStartup": false,
  "agentPushNotifEnabled": true
}
