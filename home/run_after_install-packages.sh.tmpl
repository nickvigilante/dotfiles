#!/usr/bin/env bash
# Always-run package installer.
# - Pi: stamp-and-compare against os/raspberry-pi/packages.apt; sudo apt install if changed.
# - All other machines: brew bundle check (fast no-op if satisfied) → install if not.
# Resilient per-line fallback catches single-package failures and reports them.

set -euo pipefail

# Suppress Homebrew's "Disable this behaviour by setting HOMEBREW_NO_INSTALL_CLEANUP=1"
# / "Hide these hints with HOMEBREW_NO_ENV_HINTS=1" footer noise. Per-formula
# Caveats blocks (e.g. "zsh completions installed to ...") are emitted by the
# formulae themselves and only appear during actual installs — on re-runs where
# `brew bundle check` exits 0, no caveats are shown.
export HOMEBREW_NO_ENV_HINTS=1

REPO_DIR="{{ .chezmoi.sourceDir }}/.."
GUM="${HOME}/.local/bin/gum"
[[ -x "$GUM" ]] || GUM="$(command -v gum || echo "")"

style_fail() {
    if [[ -n "$GUM" ]]; then
        "$GUM" style --foreground 213 --bold "$@"
    else
        echo "$@" >&2
    fi
}

{{ if eq .machine "pi" -}}
PKG_FILE="$REPO_DIR/os/raspberry-pi/packages.apt"
STAMP_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/dotfiles"
STAMP_FILE="$STAMP_DIR/pi-packages.stamp"
mkdir -p "$STAMP_DIR"

if [[ -f "$PKG_FILE" ]]; then
    current_hash=$(sha256sum "$PKG_FILE" | awk '{print $1}')
    last_hash=$(cat "$STAMP_FILE" 2>/dev/null || echo "")
    if [[ "$current_hash" != "$last_hash" ]]; then
        echo "==> Pi packages.apt changed — syncing..."
        sudo apt update
        grep -Ev '^#|^$' "$PKG_FILE" | xargs sudo apt install -y
        echo "$current_hash" > "$STAMP_FILE"
        echo "==> Done."
    fi
fi
exit 0
{{- end }}

{{ if and (eq .chezmoi.os "linux") (or (eq .chezmoi.arch "armv6l") (eq .chezmoi.arch "armv7l")) -}}
echo "32-bit ARM detected; Homebrew not supported on this architecture. Skipping."
exit 0
{{- end }}

BREWFILE="$HOME/.config/dotfiles/Brewfile"

if [[ ! -f "$BREWFILE" ]]; then
    echo "ERROR: $BREWFILE not yet rendered. Run 'chezmoi apply' first."
    exit 1
fi

if ! command -v brew &>/dev/null; then
    echo "ERROR: brew not on PATH. Re-run bootstrap/install.sh — Step 6/9 installs Homebrew."
    exit 1
fi

bundle_flags=(--file="$BREWFILE")
command -v code &>/dev/null || bundle_flags+=(--no-vscode)
# No `mas` entries in the Brewfile — App Store apps are installed manually
# (see README.md). Homebrew also removed the --no-mas flag in 4.x.

# `brew bundle check --quiet` still prints "can't satisfy your Brewfile's
# dependencies" on failure in current Homebrew, which looks like an error.
# Suppress its output entirely; we only care about the exit code.
if brew bundle check "${bundle_flags[@]}" --quiet &>/dev/null; then
    exit 0
fi

echo "==> Installing missing Brewfile dependencies..."
# --quiet suppresses brew bundle's "Using <pkg>" / "already installed and
# up-to-date" per-entry chatter. Per-formula caveats (e.g. "zsh completions
# installed to ...") are emitted directly by brew install on first install
# and aren't suppressible — they don't reappear on subsequent runs.
if brew bundle install "${bundle_flags[@]}" --quiet; then
    exit 0
fi

echo "==> brew bundle reported errors. Switching to per-package mode..."
failed=()

while IFS= read -r line; do
    case "$line" in
        brew\ *)
            pkg=$(echo "$line" | sed -E 's/^brew "([^"]+)".*/\1/')
            brew install "$pkg" || failed+=("$pkg")
            ;;
        cask\ *)
            pkg=$(echo "$line" | sed -E 's/^cask "([^"]+)".*/\1/')
            brew install --cask "$pkg" || failed+=("cask:$pkg")
            ;;
        vscode\ *)
            if command -v code &>/dev/null; then
                pkg=$(echo "$line" | sed -E 's/^vscode "([^"]+)".*/\1/')
                code --install-extension "$pkg" --force || failed+=("vscode:$pkg")
            fi
            ;;
    esac
done < <(grep -E '^(brew|cask|vscode) ' "$BREWFILE")

if (( ${#failed[@]} > 0 )); then
    style_fail "The following packages failed to install:"
    printf '  • %s\n' "${failed[@]}"
    echo "Re-run 'chezmoi apply' or 'dotfiles update' later to retry."
fi
